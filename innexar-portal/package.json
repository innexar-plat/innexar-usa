    "eslint": "^9",
    "eslint-config-next": "16.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
