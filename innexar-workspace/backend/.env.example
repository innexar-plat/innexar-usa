# Database
DATABASE_URL=postgresql+asyncpg://workspace_user:change_me@localhost:5432/innexar_workspace
DATABASE_URL_TEST=postgresql+asyncpg://workspace_user:change_me@localhost:5432/innexar_workspace_test

# Redis (optional for MVP)
REDIS_URL=redis://localhost:6379

# Auth - use different secrets for staff vs customer
SECRET_KEY_STAFF=change-me-in-production-staff-secret
SECRET_KEY_CUSTOMER=change-me-in-production-customer-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS - comma-separated origins (WaaS USA: innexar.app, panel.innexar.app, workspace.innexar.app; backend also allows *.innexar.app via regex)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://innexar.app,https://panel.innexar.app,https://workspace.innexar.app
FRONTEND_URL=http://localhost:3000
# PORTAL_URL= for payment redirects (e.g. https://panel.innexar.app)

# Encryption for integration secrets (Fernet key, base64). If unset, derived from SECRET_KEY_STAFF.
# ENCRYPTION_KEY=

# Bootstrap token for POST /api/workspace/system/seed and setup-wizard (optional).
# If set, only requests with ?token=<value> can run seed/setup-wizard. If unset, seed only when no users exist.
# SEED_TOKEN=

# Payment (used when no IntegrationConfig in DB, or as fallback)
# Prefer configuring via setup-wizard: POST /api/workspace/system/setup-wizard with stripe/mercadopago in body.
# Mercado Pago (BRL). Checkout Pro + Assinaturas.
# MP_ACCESS_TOKEN= ou MERCADOPAGO_ACCESS_TOKEN=
# MP_PUBLIC_KEY= (opcional; frontend/card tokenization)
# MP_WEBHOOK_SECRET= (assinatura secreta do webhook; painel MP > Webhooks > Salvar gera o secret)
# Para Assinaturas (preapproval_plan): (1) Ative "Assinaturas" na app (Painel > sua app > Produtos).
# (2) Credenciais de teste (TEST-) não existem para Assinaturas; use credenciais de PRODUÇÃO (APP_USR-...)
#     de uma conta de teste. Ver https://www.mercadopago.com.br/developers/pt/docs/credentials
# URL de notificação no painel: https://api.innexar.com.br/api/public/webhooks/mercadopago
# Eventos: subscription_preapproval (Assinaturas) e payment (Checkout Pro).
# Stripe (other currencies). Configure para usar as chaves live:
# STRIPE_SECRET_KEY=sk_live_...  (ou STRIPE_API_KEY=)
# STRIPE_WEBHOOK_SECRET=whsec_...  (assinatura do webhook; Stripe Dashboard > Webhooks > Signing secret)
# URL do webhook no Stripe: https://<sua-api>/api/public/webhooks/stripe
