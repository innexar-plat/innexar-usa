# --- Monorepo root: innexar-usa ---
# Covers: innexar-portal, innexar-website, innexar-workspace, innexar-workspace-app

# -----------------------------------------------------------------------------
# Environment and secrets (never commit)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Node / Next.js
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.next/
out/
build/
dist/
.vercel
.swc
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage
*.egg-info/
.eggs/
*.egg

# -----------------------------------------------------------------------------
# IDE / OS
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# -----------------------------------------------------------------------------
# Logs and debug
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# Docker / deploy
# -----------------------------------------------------------------------------
.docker/

# -----------------------------------------------------------------------------
# Testing / coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.pem
